rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isAdmin() { return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)); }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // Validation Helpers
    function isValidNewsStory(data) {
      return data.title is string && data.title.size() <= 200 &&
             data.content is string && data.content.size() <= 2000 &&
             data.category in ['my_feed', 'finance', 'timelines', 'insights', 'videos'] &&
             data.publishedAt is timestamp;
    }

    function isValidUser(data) {
      return data.email is string && data.email.size() <= 256 &&
             (data.bookmarks == null || data.bookmarks is list) &&
             (data.interests == null || data.interests is list);
    }

    function isValidStock(data) {
      return data.symbol is string && data.symbol.size() <= 10 &&
             data.price is number;
    }

    // Collections
    match /news/{newsId} {
      allow read: if true; // Public news
      allow create, update, delete: if isAdmin();
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId) && isValidUser(incoming());
    }

    match /stocks/{stockId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false; // System only
    }
  }
}
